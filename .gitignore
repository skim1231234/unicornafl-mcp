# ───── Project-specific ─────

# Python venv created by setup.sh
.venv/
venv/
env/

# Runtime artifacts (snapshots, generated harness, AFL in/out, fuzz logs)
work/

# External dependencies cloned by setup.sh — these are upstream projects,
# never commit them into this repo.
vendor/
# legacy default location (pre-vendor/ layout)
unicornafl-main/

# Auto-generated by setup.sh — contains user-specific absolute paths
claude_desktop_config.local.json


# ───── Python ─────

__pycache__/
*.py[cod]
*$py.class
*.so

